# Game Time Tracker environment template
# Copy this file to .env and replace values as needed.

# Shared authentication (client + server)
TRACKER_API_KEY=change-me

# Server settings
TRACKER_SERVER_ADDR=:8080
TRACKER_HISTORY_FILE=playtime_history.json

# Client settings
TRACKER_SERVER_URL=http://localhost:8080
TRACKER_CLIENT_CONFIG=config.json
TRACKER_OVERLAY=true
TRACKER_START_HIDDEN=true

# Repository mode (planned mysql support)
HISTORY_BACKEND=json

# Database settings (used when HISTORY_BACKEND=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=tracker
DB_PASSWORD=change-me
DB_NAME=game_time_tracker
MYSQL_ROOT_PASSWORD=root-change-me
