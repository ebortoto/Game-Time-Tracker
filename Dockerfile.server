FROM golang:1.25 AS build
WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /out/tracker-server ./cmd/server

FROM gcr.io/distroless/base-debian12
WORKDIR /app
COPY --from=build /out/tracker-server /app/tracker-server
COPY --from=build /src/migrations /app/migrations

EXPOSE 8080
ENTRYPOINT ["/app/tracker-server"]
